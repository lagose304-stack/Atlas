{
  "name": "atlas-react-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "npx kill-port 5173 && vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "npm run dev:backend",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "publish:github": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"git add -A; git diff --cached --quiet; if ($LASTEXITCODE -eq 0) { Write-Host 'No hay cambios para publicar.'; exit 0 }; $msg = 'chore: publish ' + (Get-Date -Format 'yyyy-MM-dd HH:mm:ss'); git commit -m $msg; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; git push origin main\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "axios": "^1.13.4",
    "cloudinary": "^2.9.0",
    "dompurify": "^3.3.3",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.0",
    "typescript": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "vite": "^4.4.5"
  }
}
